<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Professional university colour scale:
          Primary   — Deep Navy Blue  #1A237E
          Secondary — Indigo Accent   #5C6BC0
          Background — Light Grey     #F5F5F5
    -->
    <!-- Circular crop for ShapeableImageView -->
    <style name="CircleImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="Theme.CourseSchedule" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Brand colours -->
        <item name="colorPrimary">@color/navy_800</item>
        <item name="colorPrimaryVariant">@color/navy_900</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/navy_400</item>
        <item name="colorSecondaryVariant">@color/navy_600</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Surface / background -->
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/grey_900</item>
        <item name="android:colorBackground">@color/grey_100</item>
        <item name="android:windowBackground">@color/grey_100</item>

        <!-- Status bar matches the darkest navy -->
        <item name="android:statusBarColor">@color/navy_900</item>

        <!-- Error -->
        <item name="colorError">@color/error_red</item>
    </style>
</resources>
