<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/grey_100">

    <!--
        UI State Machine (Room Database as single source of truth):
        EMPTY_STATE:          FAB + hint visible. No file selected, no DB records.
        FILE_SELECTED_STATE:  Filename + "SYNC DATA TO SYSTEM" button visible.
        DATA_LOADED_STATE:    RecyclerView visible + persistent "Update Data" FAB.
    -->

    <!-- Empty-state label shown alongside the FAB before any file is imported -->
    <TextView
        android:id="@+id/tvEmptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/data_empty_state"
        android:textSize="14sp"
        android:textColor="@color/grey_700"
        android:layout_marginBottom="12dp"
        app:layout_constraintBottom_toTopOf="@id/fabImport"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Centred import FAB — the sole visible element on first open -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabImport"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="@string/fab_import_description"
        app:srcCompat="@android:drawable/ic_input_add"
        app:backgroundTint="@color/navy_800"
        app:tint="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- File selection state: shows selected filename -->
    <LinearLayout
        android:id="@+id/layoutFileSelected"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/btnProcess"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_upload"
            android:contentDescription="File icon"
            android:layout_marginBottom="8dp"
            app:tint="@color/navy_400" />

        <TextView
            android:id="@+id/tvSelectedFileName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="@color/navy_800"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="File ready for processing"
            android:textSize="12sp"
            android:textColor="@color/grey_700" />

    </LinearLayout>

    <!-- "SYNC DATA TO SYSTEM" button — visible only in the file-selected state -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnProcess"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SYNC DATA TO SYSTEM"
        android:visibility="gone"
        app:backgroundTint="@color/navy_800"
        app:icon="@android:drawable/ic_popup_sync"
        app:iconGravity="textStart"
        app:layout_constraintTop_toBottomOf="@id/layoutFileSelected"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!--
        Imported-data list (RecyclerView with lecturer cards).
        GONE until data is successfully synced to Room.
    -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvImportedData"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        android:paddingTop="8dp"
        android:paddingBottom="72dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Persistent "Update Data" FAB — visible in DATA_LOADED_STATE so Admin
         can always re-import / replace the dataset without losing access -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabUpdateData"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="Update schedule data"
        app:srcCompat="@android:drawable/ic_popup_sync"
        app:backgroundTint="@color/navy_400"
        app:tint="@color/white"
        android:layout_margin="16dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- "Push to Cloud" button for Admin — visible only when data is loaded and Firebase is configured -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPushToCloud"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PUSH TO CLOUD"
        android:visibility="gone"
        app:backgroundTint="@color/teal_500"
        app:icon="@android:drawable/ic_menu_upload"
        app:iconGravity="textStart"
        android:layout_marginEnd="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp" />

    <!-- Cloud sync status indicator -->
    <TextView
        android:id="@+id/tvCloudStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="10sp"
        android:textColor="@color/grey_600"
        android:visibility="gone"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toBottomOf="@+id/btnPushToCloud"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
