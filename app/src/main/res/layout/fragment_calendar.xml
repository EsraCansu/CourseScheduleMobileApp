<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/grey_100"
    android:padding="12dp">

    <!-- Mode Toggle for Lecturers -->
    <LinearLayout
        android:id="@+id/layoutModeToggle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="8dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mode:"
            android:textColor="@color/grey_700"
            android:layout_marginEnd="8dp" />

        <ToggleButton
            android:id="@+id/toggleAvailabilityMode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textOn="Set Availability"
            android:textOff="View Schedule"
            android:checked="false" />
    </LinearLayout>

    <!-- Department Spinner — visible only for Admin role, GONE for Lecturer -->
    <Spinner
        android:id="@+id/spinnerDepartment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:padding="4dp"
        android:layout_marginBottom="12dp"
        android:visibility="gone" />

    <!-- Schedule Grid wrapped in a ScrollView for small screens -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <TableLayout
            android:id="@+id/tableSchedule"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:stretchColumns="1,2"
            android:shrinkColumns="1,2">

            <!-- ── Header Row ─────────────────────────────────────────── -->
            <TableRow android:background="@color/navy_800">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="80dp"
                    android:padding="10dp"
                    android:text=""
                    android:textColor="@color/white" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:padding="10dp"
                    android:text="Morning"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:padding="10dp"
                    android:text="Afternoon"
                    android:textColor="@color/white"
                    android:textStyle="bold" />
            </TableRow>

            <!-- ── Monday ─────────────────────────────────────────────── -->
            <TableRow>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="80dp"
                    android:padding="10dp"
                    android:text="Monday"
                    android:textColor="@color/grey_900"
                    android:textStyle="bold"
                    android:background="@color/navy_200" />

                <TextView
                    android:id="@+id/cell00"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="64dp"
                    android:gravity="center"
                    android:padding="8dp"
                    android:textSize="12sp"
                    android:textColor="@color/grey_900"
                    android:background="@color/white" />

                <TextView
                    android:id="@+id/cell01"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="64dp"
                    android:gravity="center"
                    android:padding="8dp"
                    android:textSize="12sp"
                    android:textColor="@color/grey_900"
                    android:background="@color/grey_50" />
            </TableRow>

            <!-- ── Tuesday ────────────────────────────────────────────── -->
            <TableRow>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="80dp"
                    android:padding="10dp"
                    android:text="Tuesday"
                    android:textColor="@color/grey_900"
                    android:textStyle="bold"
                    android:background="@color/navy_200" />

                <TextView
                    android:id="@+id/cell10"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="64dp"
                    android:gravity="center"
                    android:padding="8dp"
                    android:textSize="12sp"
                    android:textColor="@color/grey_900"
                    android:background="@color/white" />

                <TextView
                    android:id="@+id/cell11"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="64dp"
                    android:gravity="center"
                    android:padding="8dp"
                    android:textSize="12sp"
                    android:textColor="@color/grey_900"
                    android:background="@color/grey_50" />
            </TableRow>

            <!-- ── Wednesday ──────────────────────────────────────────── -->
            <TableRow>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="80dp"
                    android:padding="10dp"
                    android:text="Wednesday"
                    android:textColor="@color/grey_900"
                    android:textStyle="bold"
                    android:background="@color/navy_200" />

                <TextView
                    android:id="@+id/cell20"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="64dp"
                    android:gravity="center"
                    android:padding="8dp"
                    android:textSize="12sp"
                    android:textColor="@color/grey_900"
                    android:background="@color/white" />

                <TextView
                    android:id="@+id/cell21"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="64dp"
                    android:gravity="center"
                    android:padding="8dp"
                    android:textSize="12sp"
                    android:textColor="@color/grey_900"
                    android:background="@color/grey_50" />
            </TableRow>

            <!-- ── Thursday ───────────────────────────────────────────── -->
            <TableRow>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="80dp"
                    android:padding="10dp"
                    android:text="Thursday"
                    android:textColor="@color/grey_900"
                    android:textStyle="bold"
                    android:background="@color/navy_200" />

                <TextView
                    android:id="@+id/cell30"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="64dp"
                    android:gravity="center"
                    android:padding="8dp"
                    android:textSize="12sp"
                    android:textColor="@color/grey_900"
                    android:background="@color/white" />

                <TextView
                    android:id="@+id/cell31"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="64dp"
                    android:gravity="center"
                    android:padding="8dp"
                    android:textSize="12sp"
                    android:textColor="@color/grey_900"
                    android:background="@color/grey_50" />
            </TableRow>

            <!-- ── Friday ─────────────────────────────────────────────── -->
            <TableRow>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="80dp"
                    android:padding="10dp"
                    android:text="Friday"
                    android:textColor="@color/grey_900"
                    android:textStyle="bold"
                    android:background="@color/navy_200" />

                <TextView
                    android:id="@+id/cell40"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="64dp"
                    android:gravity="center"
                    android:padding="8dp"
                    android:textSize="12sp"
                    android:textColor="@color/grey_900"
                    android:background="@color/white" />

                <TextView
                    android:id="@+id/cell41"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:minHeight="64dp"
                    android:gravity="center"
                    android:padding="8dp"
                    android:textSize="12sp"
                    android:textColor="@color/grey_900"
                    android:background="@color/grey_50" />
            </TableRow>

        </TableLayout>
    </ScrollView>

</LinearLayout>
