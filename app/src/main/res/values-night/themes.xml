<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark mode overrides for Theme.CourseSchedule -->
    <style name="CircleImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="Theme.CourseSchedule" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Brand colours remain the same in dark mode -->
        <item name="colorPrimary">@color/brand_500</item>
        <item name="colorPrimaryVariant">@color/brand_900</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/brand_300</item>
        <item name="colorSecondaryVariant">@color/brand_700</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Dark surfaces -->
        <item name="colorSurface">#1E1E1E</item>
        <item name="colorOnSurface">#E0E0E0</item>
        <item name="android:colorBackground">#121212</item>
        <item name="android:windowBackground">#121212</item>

        <!-- Status bar — dark -->
        <item name="android:statusBarColor">#121212</item>

        <!-- Error -->
        <item name="colorError">@color/error_red</item>
    </style>
</resources>
