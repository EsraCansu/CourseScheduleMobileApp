# Android build outputs — excluded to prevent OneDrive/file-lock conflicts
# during Gradle incremental builds (the "Unable to delete directory" error).
*.iml
.gradle/
local.properties
.idea/caches
.idea/libraries
.idea/modules.xml
.idea/workspace.xml
.idea/navEditor.xml
.idea/assetWizardSettings.xml
.DS_Store
/build/
/captures/
.externalNativeBuild/
.cxx/
*.apk
*.aab
*.ap_
*.dex

# Firebase configuration (sensitive credentials)
app/google-services.json
